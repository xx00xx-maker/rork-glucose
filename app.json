{
  "expo": {
    "name": "血糖トラッカー",
    "slug": "ketogardian",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.ketogardian",
      "infoPlist": {
        "NSHealthShareUsageDescription": "レポート生成のために血糖値と歩数データを利用します。",
        "NSHealthUpdateUsageDescription": "データ分析のためにHealthKitへアクセスします。",
        "UIBackgroundModes": [
          "fetch",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.rork.ketogardian"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-sqlite",
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false,
          "background": true,
          "healthSharePermission": "レポート生成のために血糖値と歩数データを利用します。",
          "healthUpdatePermission": "データ分析のためにHealthKitへアクセスします。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://rork.com/"
      },
      "eas": {
        "projectId": "d77fe2f5-a2e5-44c6-827a-8db45a0ee058"
      }
    }
  }
}